APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_DSN=postgresql://app:app@postgres:5432/calls
MONGO_DSN=mongodb://mongo:27017
MONGO_DATABASE=mango_calls
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_PREFIX=mango-calls-local

OPENAI_API_KEY=replace-me
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_QUALITY_MODEL=gpt-4o-mini
OPENAI_QUALITY_TEMPERATURE=0

MANGO_API_BASE_URL=https://app.mango-office.ru/vpbx
MANGO_API_KEY=replace-me
MANGO_API_SALT=replace-me
MANGO_STATS_REQUEST_ENDPOINT=stats/request
MANGO_STATS_RESULT_ENDPOINT=stats/result
MANGO_RECORDING_DOWNLOAD_ENDPOINT=records/{recording_id}
MANGO_POLL_INTERVAL_SECONDS=30
MANGO_LOOKBACK_SECONDS=300
MANGO_REQUEST_WINDOW_SECONDS=300
MANGO_RESULT_POLL_ATTEMPTS=12
MANGO_RESULT_POLL_INTERVAL_SECONDS=5
MANGO_STATS_FIELDS=records,start,finish,from_extension,from_number,to_extension,to_number,disconnect_reason
MANGO_DEFAULT_TIMEZONE=Europe/Moscow

TOPIC_MANGO_RAW=mango.calls.raw
TOPIC_TO_TRANSCRIBE=calls.to_transcribe
TOPIC_TRANSCRIBED=calls.transcribed
TOPIC_QUALITY=calls.quality
TOPIC_DEAD_LETTER=calls.dead_letter

API_HOST=0.0.0.0
API_PORT=8080

APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_DSN=postgresql://app:app@postgres:5432/calls
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_PREFIX=mango-calls-local
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=4
OUTBOX_BATCH_SIZE=100

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mango-calls
MINIO_SECURE=false
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_PRESIGNED_URL_EXPIRES_SECONDS=604800

OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=Mango Transcribe Analysis
OPENAI_TRANSCRIBE_MODEL=openai/gpt-4o-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=ru
OPENAI_TRANSCRIPT_ROLE_MODEL=openai/gpt-4o-mini
OPENAI_QUALITY_MODEL=openai/gpt-4o-mini
OPENAI_QUALITY_TEMPERATURE=0

MANGO_API_BASE_URL=https://app.mango-office.ru/vpbx
MANGO_API_KEY=replace-me
MANGO_API_SALT=replace-me
MANGO_STATS_REQUEST_ENDPOINT=stats/request
MANGO_STATS_RESULT_ENDPOINT=stats/result
MANGO_RECORDING_DOWNLOAD_ENDPOINT=queries/recording/post/
MANGO_POLL_INTERVAL_SECONDS=30
MANGO_CATCHUP_INTERVAL_SECONDS=1
MANGO_LOOKBACK_SECONDS=300
MANGO_REQUEST_WINDOW_SECONDS=300
MANGO_RESULT_POLL_ATTEMPTS=60
MANGO_RESULT_POLL_INTERVAL_SECONDS=10
MANGO_WORKER_CONCURRENCY=2
MANGO_RECORDING_DOWNLOAD_INTERVAL_SECONDS=2
MANGO_TEST_LATEST_CALL_ONLY=false
MANGO_TEST_LOOKBACK_SECONDS=604800
MANGO_STATS_FIELDS=records,start,finish,answer,from_extension,from_number,to_extension,to_number,disconnect_reason,line_number,location,entry_id
MANGO_DEFAULT_TIMEZONE=Europe/Moscow

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_IDS=-100000000001,-100000000002
TELEGRAM_ERROR_BOT_TOKEN=replace-me
TELEGRAM_ERROR_CHAT_IDS=-100000000003,-100000000004
TELEGRAM_API_BASE_URL=https://api.telegram.org

TOPIC_MANGO_RAW=mango.calls.raw
TOPIC_TO_TRANSCRIBE=calls.to_transcribe
TOPIC_TO_ANALYZE=calls.to_analyze
TOPIC_TO_NOTIFY=calls.to_notify
TOPIC_DEAD_LETTER=calls.dead_letter

API_HOST=0.0.0.0
API_PORT=8080
